{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "schedule:daily"],
  "dependencyDashboard": false,
  "packageRules": [
    {
      "matchPackageNames": ["@anthropic-ai/claude-code", "opencode-ai", "opencode-gemini-auth"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "rebase"
    }
  ],
  "customDatasources": {
    "antigravity-cli": {
      "defaultRegistryUrlTemplate": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/linux_amd64.json",
      "format": "json",
      "transformTemplates": ["{\"releases\": [{\"version\": version}]}"]
    }
  }
}
